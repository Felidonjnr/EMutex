# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id_here
VITE_FIREBASE_DATABASE_ID=(default)

# Admin Authentication
# Comma-separated list of approved admin emails
VITE_ADMIN_EMAILS=admin@example.com,godshand@example.com

# Public Contact Info
VITE_WHATSAPP_NUMBER=234...

# Google Form Integration (for Custom Lead Form)
# Example: https://docs.google.com/forms/u/0/d/e/12345ABCDE/formResponse
VITE_GOOGLE_FORM_ACTION_URL=
# Example: entry.123456789
VITE_GOOGLE_FORM_ENTRY_FULL_NAME=
VITE_GOOGLE_FORM_ENTRY_WHATSAPP_NUMBER=
VITE_GOOGLE_FORM_ENTRY_LOCATION=
VITE_GOOGLE_FORM_ENTRY_PRODUCT_INTERESTED=
