rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net: Default deny everything
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Global Helpers ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Auth tokens reflect the current user's email from metadata
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.email_verified == true && request.auth.token.email.lower() == "godshandudoh@gmail.com")
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validation Blueprints (Anti-Update-Gap) ---

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'slug', 'category', 'imageUrl', 'visible', 'productOrder'])
        && data.keys().size() >= 6
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.slug is string && data.slug.size() > 0 && data.slug.size() <= 200
        && data.category is string && data.category.size() <= 100
        && data.imageUrl is string && data.imageUrl.size() <= 1000
        && data.visible is bool
        && data.productOrder is number;
    }

    function isValidLead(data) {
      return data.keys().hasAll(['fullName', 'whatsappNumber', 'productInterested', 'status', 'createdAt'])
        && data.keys().size() >= 5
        && data.fullName is string && data.fullName.size() >= 2 && data.fullName.size() <= 200
        && data.whatsappNumber is string && data.whatsappNumber.size() >= 10 && data.whatsappNumber.size() <= 50
        && data.productInterested is string && data.productInterested.size() > 0
        && data.status in ['New', 'Contacted', 'Interested', 'Ordered', 'Not Ready', 'Follow Up Later']
        && data.createdAt == request.time;
    }

    function isValidWellnessNeed(data) {
      return data.keys().hasAll(['title', 'description', 'whatsappTopic'])
        && data.keys().size() >= 3
        && data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && data.description is string && data.description.size() <= 1000
        && data.whatsappTopic is string && data.whatsappTopic.size() <= 200;
    }

    function isValidBundle(data) {
      return data.keys().hasAll(['name', 'slug', 'imageUrl', 'visible', 'order'])
        && data.keys().size() >= 5
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.slug is string && data.slug.size() > 0 && data.slug.size() <= 200
        && (data.category == null || (data.category is string && data.category.size() <= 100))
        && (data.imageUrl == null || (data.imageUrl is string && data.imageUrl.size() <= 1000))
        && data.visible is bool
        && data.order is number;
    }

    // --- Collection Rules ---

    // Products: Secure List Queries (The "Query Enforcer")
    match /products/{productId} {
      allow get: if true;
      allow list: if resource.data.visible == true || isAdmin();
      allow create: if isValidProduct(incoming()) && isAdmin() && isValidId(productId);
      allow update: if isValidProduct(incoming()) && (
        isAdmin() || 
        (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['viewCount'])) // Example of tiered update
      );
      allow delete: if isAdmin();
    }

    // Wellness Needs
    match /wellnessNeeds/{needId} {
      allow get: if true;
      allow list: if true; // No visible field defined yet for needs in blueprint
      allow create: if isValidWellnessNeed(incoming()) && isAdmin() && isValidId(needId);
      allow update: if isValidWellnessNeed(incoming()) && isAdmin();
      allow delete: if isAdmin();
    }

    // Bundles
    match /bundles/{bundleId} {
      allow get: if true;
      allow list: if resource.data.visible == true || isAdmin();
      allow create: if isValidBundle(incoming()) && isAdmin() && isValidId(bundleId);
      allow update: if isValidBundle(incoming()) && isAdmin();
      allow delete: if isAdmin();
    }

    // Leads: PII Isolation & Identity Integrity
    match /leads/{leadId} {
      allow create: if isValidLead(incoming()) && isValidId(leadId);
      allow read, list, update, delete: if isAdmin();
    }

    // Settings: Global Config
    match /settings/{settingId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Categories: Publicly readable
    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidId(categoryId);
    }

    // Admin records: Private to the specific admin user
    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
      allow write: if false; 
    }
  }
}
